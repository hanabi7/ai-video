# AI-Voice 环境配置

# 服务端口
PORT=3002

# 百度智能云 TTS
# https://cloud.baidu.com/product/speech/tts
BAIDU_APP_ID=your_baidu_app_id
BAIDU_API_KEY=your_baidu_api_key
BAIDU_SECRET_KEY=your_baidu_secret_key

# 讯飞开放平台
# https://www.xfyun.cn/services/online_tts
XUNFEI_APP_ID=your_xunfei_app_id
XUNFEI_API_KEY=your_xunfei_api_key
XUNFEI_API_SECRET=your_xunfei_api_secret

# MiniMax
# https://www.minimax.io/
MINIMAX_API_KEY=your_minimax_api_key
MINIMAX_GROUP_ID=your_minimax_group_id

# 阿里云 (可选)
# https://www.aliyun.com/product/nls
ALIYUN_ACCESS_KEY_ID=your_aliyun_key
ALIYUN_ACCESS_KEY_SECRET=your_aliyun_secret

# CosyVoice 配置
COSYVOICE_MODEL_PATH=../models/CosyVoice

# Redis 配置（用于任务队列，可选）
REDIS_URL=redis://localhost:6379
