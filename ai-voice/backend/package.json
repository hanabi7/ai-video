    "bull": "^4.12.0",
    "redis": "^4.6.0",
    "uuid": "^9.0.0",
    "fs-extra": "^11.1.0",
    "dotenv": "^16.3.0",
    "ws": "^8.14.0",
    "form-data": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@types/fs-extra": "^11.0.4",
    "typescript": "^5.3.0",
    "ts-node-dev": "^2.0.0"
